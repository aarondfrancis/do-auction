{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "durable-auction-live",
  "main": "src/index.ts",

  "workers_dev": true,
  "compatibility_date": "2026-03-17",
  "durable_objects": {
    "bindings": [
      {
        "name": "AUCTION",
        "class_name": "AuctionRoom"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["AuctionRoom"]
    }
  ]
}
